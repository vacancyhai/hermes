# ============================================================
# Hermes — Environment Variable Reference
# ============================================================
# Copy this file to src/backend/.env (never commit the real .env).
# All variables consumed by src/backend/app/config.py are listed here.
# Variables marked "REQUIRED in production" have no safe default and
# MUST be set before starting the production stack.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
SECRET_KEY=change-me-in-production         # REQUIRED in production — random 32-byte hex
BACKEND_PORT=8000

# ── PostgreSQL (accessed through PgBouncer) ──────────────────
POSTGRES_DB=hermes_db
POSTGRES_USER=hermes_user
POSTGRES_PASSWORD=change-me               # REQUIRED — never leave default
DATABASE_URL=postgresql+asyncpg://hermes_user:change-me@pgbouncer:5432/hermes_db
DB_POOL_SIZE=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=                            # Leave blank to disable Redis AUTH (dev only)
REDIS_KEY_PREFIX=hermes

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Email ────────────────────────────────────────────────────
MAIL_ENABLED=false                         # Set true to actually send emails
MAIL_SERVER=mailpit                        # Use OCI SMTP host in production
MAIL_PORT=1025                             # 587 for TLS (production)
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret        # REQUIRED in production — random 64-byte hex
JWT_ACCESS_TOKEN_EXPIRES=900               # seconds (15 min)
JWT_REFRESH_TOKEN_EXPIRES=604800           # seconds (7 days)

# ── Firebase Auth ────────────────────────────────────────────
# Service account JSON for firebase-admin SDK (server-side token verification)
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-credentials.json
# JS SDK config values (served to the frontend — not secret, but project-specific)
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8080","http://localhost:8081"]

# ── Frontend / SEO ───────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
SITE_URL=http://localhost
SITEMAP_PATH=/app/sitemap.xml

# ── PDF ingestion & AI extraction ───────────────────────────
PDF_UPLOAD_DIR=/app/uploads/pdfs
PDF_MAX_SIZE_MB=10
PDF_KEEP_AFTER_EXTRACTION=false
ANTHROPIC_API_KEY=                         # REQUIRED to use AI PDF extraction
AI_MODEL=claude-3-5-sonnet-20241022

# ── Notification delivery delays (seconds) ───────────────────
NOTIFY_EMAIL_DELAY=900                     # 15 min stagger before email delivery
NOTIFY_WHATSAPP_DELAY=3600                 # 1 hour stagger
NOTIFY_TELEGRAM_DELAY=900                  # 15 min stagger

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                        # Leave blank to disable Telegram notifications
