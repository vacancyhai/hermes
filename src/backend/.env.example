# Backend Service Environment Variables

# Backend Port
BACKEND_PORT=5000

# PostgreSQL Configuration
DB_USER=hermes_user
DB_PASSWORD=your_secure_password_here
DB_NAME=hermes_db
DB_HOST=postgresql
DB_PORT=5432
DATABASE_URL=postgresql://hermes_user:your_secure_password_here@postgresql:5432/hermes_db

# PostgreSQL Connection Pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@redis:6379/0

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters

# JWT Token Expiration
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=604800  # 7 days

# Celery Configuration
CELERY_BROKER_URL=redis://:your_redis_password_here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your_redis_password_here@redis:6379/1

# Email Configuration (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Firebase Configuration (for push notifications)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# CORS Configuration (Allow frontend origins)
# Development: http://localhost:8080
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:8080,http://frontend:8080

# Rate Limiting
RATE_LIMIT_PER_IP=100  # requests per minute
RATE_LIMIT_PER_USER=1000  # requests per minute
RATE_LIMIT_LOGIN=5  # login attempts per minute

# API Configuration
API_REQUEST_TIMEOUT=10  # seconds
DB_CONNECTION_TIMEOUT=5  # seconds

# Data Retention (Days)
NOTIFICATION_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30
AUDIT_TRAIL_RETENTION_DAYS=365

# Connection Pooling
REDIS_MAX_CONNECTIONS=50
