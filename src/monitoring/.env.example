# Prometheus Configuration
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana Configuration
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=securepassword123
GRAFANA_ORG_NAME=Hermes
GRAFANA_ORG_ROLE=Admin

# AlertManager Configuration
ALERTMANAGER_PORT=9093

# Exporters Ports
NODE_EXPORTER_PORT=9100
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121
NGINX_EXPORTER_PORT=9113
CADVISOR_PORT=8080

# Alert Routing - Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts
SLACK_USERNAME=HermesAlerts

# Alert Routing - Email
EMAIL_CRITICAL_ALERTS=critical-alerts@example.com
EMAIL_DBA=dba@example.com
EMAIL_OPS=ops@example.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=alerts@hermes-platform.com

# Alert Routing - PagerDuty
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# PostgreSQL Exporter
POSTGRES_EXPORTER_USER=hermes_user
POSTGRES_EXPORTER_PASSWORD=hermes_password
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=hermes_db

# Redis Exporter
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Nginx Exporter
NGINX_SCRAPE_URL=http://nginx:80/nginx_status
