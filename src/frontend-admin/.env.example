# ============================================================
# Hermes Admin Frontend — Environment Variable Reference
# ============================================================
# Copy this file to src/frontend-admin/.env (never commit the real .env).
# Variables consumed by src/frontend-admin/app/__init__.py via python-dotenv.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_APP=app:app
FLASK_ENV=development           # development | production
FLASK_DEBUG=1                   # Set 0 in production
FRONTEND_ADMIN_PORT=8081

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production  # REQUIRED in production — different from backend + user frontend
SESSION_TIMEOUT=3600                # seconds (1 hour)

# ── Backend API ──────────────────────────────────────────────
# Use Docker service name in Docker Compose (backend), or full URL in production
BACKEND_API_URL=http://backend:8000/api/v1
