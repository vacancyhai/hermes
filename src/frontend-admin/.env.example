# Admin Frontend Service Environment Variables

# Admin Frontend Port
FRONTEND_ADMIN_PORT=8081

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-admin-frontend-secret-key-minimum-32-characters

# Backend API URL - CRITICAL CONFIGURATION
# This tells the admin frontend where to find the backend API

# Development (same machine):
BACKEND_API_URL=http://localhost:5000/api/v1

# Production (different server - update with your backend server IP/domain):
# BACKEND_API_URL=http://192.168.1.10:5000/api/v1
# BACKEND_API_URL=https://api.yourdomain.com/api/v1

# Session Configuration
# 1 hour
SESSION_TIMEOUT=3600
# Set to True in production with HTTPS
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# Admin frontend-specific settings
ITEMS_PER_PAGE=50
