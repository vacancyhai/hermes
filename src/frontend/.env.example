# ============================================================
# Hermes User Frontend — Environment Variable Reference
# ============================================================
# Copy this file to src/frontend/.env (never commit the real .env).
# Variables consumed by src/frontend/app/__init__.py via python-dotenv.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_APP=app:app
FLASK_ENV=development           # development | production
FLASK_DEBUG=1                   # Set 0 in production
FRONTEND_PORT=8080

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production  # REQUIRED in production — random 32-byte hex
SESSION_TIMEOUT=3600                # seconds (1 hour)

# ── Backend API ──────────────────────────────────────────────
# Use Docker service name in Docker Compose (backend), or full URL in production
BACKEND_API_URL=http://backend:8000/api/v1

# ── Firebase Auth (JS SDK — served to browser) ───────────────
# These are not secret — they identify the Firebase project, not grant admin access
FIREBASE_WEB_API_KEY=            # REQUIRED — from Firebase Console → Project Settings
FIREBASE_AUTH_DOMAIN=            # e.g. your-project.firebaseapp.com
FIREBASE_PROJECT_ID=             # e.g. your-project
