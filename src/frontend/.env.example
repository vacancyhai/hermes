# ============================================================
# Hermes React Frontend — Environment Variable Reference
# ============================================================
# Copy this file to .env.local for local dev (never commit real values).
# Prefix all browser-exposed vars with VITE_.
# ============================================================

# ── Backend API ──────────────────────────────────────────────
# Use Docker service name in Docker Compose, or full URL in production
VITE_BACKEND_API_URL=http://backend:8000/api/v1

# ── Firebase Auth (JS SDK — served to browser) ───────────────
# These are not secret — they identify the Firebase project
VITE_FIREBASE_API_KEY=            # REQUIRED — from Firebase Console → Project Settings
VITE_FIREBASE_AUTH_DOMAIN=        # e.g. your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=         # e.g. your-project
