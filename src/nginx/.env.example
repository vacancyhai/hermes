# Nginx Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Backend API URL (for upstream proxy)
BACKEND_URL=http://backend:5000

# Frontend URL (for upstream proxy)
FRONTEND_URL=http://frontend:8080

# SSL Configuration (for production HTTPS)
# Uncomment and set these paths when using HTTPS
# SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
# SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem
# SSL_DHPARAM_PATH=/etc/nginx/ssl/dhparam.pem

# Rate limiting (requests per second)
RATE_LIMIT=10

# Logging level
LOG_LEVEL=info

# Health check path
HEALTH_CHECK_PATH=/health
