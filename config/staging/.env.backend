APP_ENV=staging
SECRET_KEY=CHANGE_ME_32_BYTE_HEX
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_DB=hermes_db
POSTGRES_USER=hermes_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://hermes_user:CHANGE_ME@pgbouncer:5432/hermes_db
DB_POOL_SIZE=20

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME
REDIS_KEY_PREFIX=hermes

# Celery
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/0

# Email
MAIL_ENABLED=true
MAIL_SERVER=smtp.your-provider.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_DEFAULT_SENDER=noreply@your-domain.com

# JWT
JWT_SECRET_KEY=CHANGE_ME_64_BYTE_HEX
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# CORS
CORS_ORIGINS=["https://staging.your-domain.com","https://admin.staging.your-domain.com"]

# SEO / Sitemap
FRONTEND_URL=https://staging.your-domain.com
SITE_URL=https://staging.your-domain.com
SITEMAP_PATH=/app/sitemap.xml

# PDF ingestion & AI extraction
PDF_UPLOAD_DIR=/app/uploads/pdfs
PDF_MAX_SIZE_MB=10
PDF_KEEP_AFTER_EXTRACTION=false
ANTHROPIC_API_KEY=CHANGE_ME
AI_MODEL=claude-3-5-sonnet-20241022

# Notification delivery delays (seconds)
NOTIFY_EMAIL_DELAY=900
NOTIFY_WHATSAPP_DELAY=3600
NOTIFY_TELEGRAM_DELAY=900

# Telegram Bot
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Firebase Auth
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-credentials.json
FIREBASE_WEB_API_KEY=CHANGE_ME
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
