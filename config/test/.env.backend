# Backend — Test / CI Environment
APP_ENV=test
SECRET_KEY=ci-secret-key  # pragma: allowlist secret
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_DB=hermes_test_db
POSTGRES_USER=hermes_user
POSTGRES_PASSWORD=hermes_ci_pass  # pragma: allowlist secret
DATABASE_URL=postgresql+asyncpg://hermes_user:hermes_ci_pass@pgbouncer:5432/hermes_test_db  # pragma: allowlist secret
MIGRATION_DATABASE_URL=postgresql+asyncpg://hermes_user:hermes_ci_pass@postgresql:5432/hermes_test_db  # pragma: allowlist secret
DB_POOL_SIZE=5

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=hermes

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email
MAIL_ENABLED=false
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@ci.local

# JWT
JWT_SECRET_KEY=ci-jwt-secret  # pragma: allowlist secret
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# CORS
CORS_ORIGINS=["http://localhost:8080","http://localhost:8081"]

# SEO / Sitemap
SITE_URL=http://localhost
SITEMAP_PATH=/tmp/sitemap.xml
FRONTEND_URL=http://localhost:8080

# PDF ingestion & AI extraction
PDF_UPLOAD_DIR=/tmp/uploads/pdfs
PDF_MAX_SIZE_MB=10
PDF_KEEP_AFTER_EXTRACTION=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-3-5-sonnet-20241022

# Notification delivery delays (seconds)
NOTIFY_EMAIL_DELAY=900
NOTIFY_WHATSAPP_DELAY=3600
NOTIFY_TELEGRAM_DELAY=900

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Firebase Auth
FIREBASE_CREDENTIALS_PATH=
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
