		{
			"name": "Notifications",
			"item": [
				{
					"name": "List Notifications",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.data && json.data.length > 0) {",
									"    pm.collectionVariables.set('notification_id', json.data[0].id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/notifications?limit=20&offset=0",
							"host": ["{{base_url}}"],
							"path": ["notifications"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "offset", "value": "0" },
								{ "key": "type", "value": "", "disabled": true },
								{ "key": "is_read", "value": "false", "disabled": true }
							]
						},
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				},
				{
					"name": "Unread Count",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/notifications/count",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				},
				{
					"name": "Mark Notification as Read",
					"request": {
						"method": "PUT",
						"url": "{{base_url}}/notifications/{{notification_id}}/read",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				},
				{
					"name": "Mark All as Read",
					"request": {
						"method": "PUT",
						"url": "{{base_url}}/notifications/read-all",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				},
				{
					"name": "Delete Notification",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/notifications/{{notification_id}}",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				}
			]
		},
		{
			"name": "FCM & Notification Preferences",
			"item": [
				{
					"name": "Register FCM Token",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/users/me/fcm-token",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"YOUR_FCM_DEVICE_TOKEN_HERE\",\n  \"device_name\": \"Chrome Desktop\"\n}"
						}
					}
				},
				{
					"name": "Unregister FCM Token",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/users/me/fcm-token",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"YOUR_FCM_DEVICE_TOKEN_HERE\"\n}"
						}
					}
				},
				{
					"name": "Update Notification Preferences",
					"request": {
						"method": "PUT",
						"url": "{{base_url}}/users/me/notification-preferences",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": true,\n  \"push\": true,\n  \"in_app\": true\n}"
						}
					}
				}
			]
		}
	]
