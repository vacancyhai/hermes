					"description": "Set password for Google OAuth users who don't have a password yet. Password must have min 8 chars, 1 uppercase, 1 special character.",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/users/me/set-password",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{user_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"new_password\": \"NewPass@123\"\n}"
						}
					}
				},
				{
					"name": "Change Password",
					"description": "Change password (requires current password). New password must have min 8 chars, 1 uppercase, 1 special character.",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/users/me/change-password",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{user_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"current_password\": \"OldPass@123\",\n  \"new_password\": \"NewPass@456\"\n}"
						}
					}
				},
				{
					"name": "Link Email+Password to Phone Account",
					"description": "Link email and password credentials to a phone-only account. Password must have min 8 chars, 1 uppercase, 1 special character.",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/users/me/link-email-password",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{user_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"myemail@example.com\",\n  \"password\": \"MyPass@123\"\n}"
						}
					}
				}
