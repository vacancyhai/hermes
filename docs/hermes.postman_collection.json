{
	"info": {
		"name": "Hermes – Gov Job Portal",
		"description": "API collection for Hermes Government Job Vacancy Portal.\n\nVariables:\n- `base_url` → http://localhost:8000/api/v1\n- `user_token` → set automatically after user login\n- `admin_token` → set automatically after admin login\n- `refresh_token` / `admin_refresh_token` → set after login\n- `notification_id` → set after listing notifications",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api/v1"
		},
		{
			"key": "user_token",
			"value": ""
		},
		{
			"key": "admin_token",
			"value": ""
		},
		{
			"key": "refresh_token",
			"value": ""
		},
		{
			"key": "admin_refresh_token",
			"value": ""
		},
		{
			"key": "job_id",
			"value": ""
		},
		{
			"key": "job_slug",
			"value": ""
		},
		{
			"key": "user_id",
			"value": ""
		},
		{
			"key": "application_id",
			"value": ""
		},
		{
			"key": "notification_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/health",
						"header": []
					}
				}
			]
		},
		{
			"name": "Auth – User (Email OTP Registration)",
			"item": [
				{
					"name": "Send Email OTP",
					"description": "Send OTP to email for registration. OTP expires in 10 minutes.",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/send-email-otp",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"newuser@example.com\",\n  \"full_name\": \"New User\"\n}"
						}
					}
				},
				{
					"name": "Verify Email OTP",
					"description": "Verify the 6-digit OTP sent to email. Returns verification token.",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/verify-email-otp",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"newuser@example.com\",\n  \"otp\": \"123456\"\n}"
						}
					}
				},
				{
					"name": "Complete Registration",
					"description": "Complete registration with password after OTP verification. Password must have min 8 chars, 1 uppercase, 1 special character.",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.custom_token) {",
									"    console.log('Registration complete! Use custom_token with Firebase SDK to sign in.');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/complete-registration",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"verification_token\": \"PASTE_VERIFICATION_TOKEN_HERE\",\n  \"password\": \"StrongPass@123\"\n}"
						}
					}
				},
				{
					"name": "Check Phone Availability",
					"description": "Check if a phone number is already registered.",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/check-phone-availability",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"+919876543210\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "Auth – User (Firebase)",
			"item": [
				{
					"name": "Verify Firebase Token",
					"description": "Exchange a Firebase ID token (from Firebase JS SDK) for an internal JWT pair. Creates user if new, links existing by firebase_uid or email.",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('user_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/verify-token",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_token\": \"PASTE_FIREBASE_ID_TOKEN_HERE\"\n}"
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/logout",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{user_token}}"
							}
						]
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('user_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/refresh",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
						}
					}
				}
			]
		},
