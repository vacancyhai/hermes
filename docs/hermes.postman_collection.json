		{
			"name": "Jobs – Public",
			"item": [
				{
					"name": "List Jobs",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/jobs?limit=20&offset=0",
							"host": ["{{base_url}}"],
							"path": ["jobs"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "offset", "value": "0" },
								{ "key": "q", "value": "", "disabled": true },
								{ "key": "job_type", "value": "", "disabled": true },
								{ "key": "qualification_level", "value": "", "disabled": true },
								{ "key": "organization", "value": "", "disabled": true },
								{ "key": "department", "value": "", "disabled": true },
								{ "key": "is_featured", "value": "true", "disabled": true },
								{ "key": "is_urgent", "value": "true", "disabled": true }
							]
						},
						"header": []
					}
				},
				{
					"name": "Search Jobs (FTS)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/jobs?q=SSC+CGL&limit=10",
							"host": ["{{base_url}}"],
							"path": ["jobs"],
							"query": [
								{ "key": "q", "value": "SSC CGL" },
								{ "key": "limit", "value": "10" }
							]
						},
						"header": []
					}
				},
				{
					"name": "Job Detail by Slug",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/jobs/{{job_slug}}",
						"header": []
					}
				},
				{
					"name": "Recommended Jobs",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/jobs/recommended?limit=20&offset=0",
							"host": ["{{base_url}}"],
							"path": ["jobs", "recommended"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "offset", "value": "0" }
							]
						},
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				}
			]
		},
		{
			"name": "Admin – Jobs",
			"item": [
				{
					"name": "List All Jobs (Admin)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/jobs?limit=20&offset=0",
							"host": ["{{base_url}}"],
							"path": ["admin", "jobs"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "offset", "value": "0" },
								{ "key": "status", "value": "", "disabled": true }
							]
						},
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						]
					}
				},
				{
					"name": "Create Job",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.id) {",
									"    pm.collectionVariables.set('job_id', json.id);",
									"    pm.collectionVariables.set('job_slug', json.slug);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/admin/jobs",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"job_title\": \"SSC CGL 2026\",\n  \"organization\": \"Staff Selection Commission\",\n  \"job_type\": \"latest_job\",\n  \"qualification_level\": \"graduate\",\n  \"total_vacancies\": 8000,\n  \"description\": \"Combined Graduate Level Exam 2026 recruitment.\",\n  \"application_end\": \"2026-07-15\",\n  \"fee_general\": 100,\n  \"fee_obc\": 100,\n  \"fee_sc_st\": 0,\n  \"fee_ews\": 0,\n  \"fee_female\": 0,\n  \"status\": \"draft\"\n}"
						}
					}
				},
				{
					"name": "Update Job",
					"request": {
						"method": "PUT",
						"url": "{{base_url}}/admin/jobs/{{job_id}}",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"total_vacancies\": 9000,\n  \"is_featured\": true\n}"
						}
					}
				},
				{
					"name": "Approve Job (draft → active)",
					"request": {
						"method": "PUT",
						"url": "{{base_url}}/admin/jobs/{{job_id}}/approve",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						]
					}
				},
				{
					"name": "Delete Job (Admin only)",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/admin/jobs/{{job_id}}",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						]
					}
				},
				{
					"name": "Upload PDF (AI Extraction)",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/admin/jobs/upload-pdf",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "file", "type": "file", "src": "", "description": "PDF notification file (max 10MB)" }
							]
						}
					}
				}
			]
		},
