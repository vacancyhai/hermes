{
	"info": {
		"name": "Hermes – Gov Job Portal",
		"description": "API collection for Hermes Government Job Vacancy Portal.\n\nVariables:\n- `base_url` → http://localhost:8000/api/v1\n- `user_token` → set automatically after user login\n- `admin_token` → set automatically after admin login\n- `refresh_token` / `admin_refresh_token` → set after login\n- `notification_id` → set after listing notifications",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000/api/v1" },
		{ "key": "user_token", "value": "" },
		{ "key": "admin_token", "value": "" },
		{ "key": "refresh_token", "value": "" },
		{ "key": "admin_refresh_token", "value": "" },
		{ "key": "job_id", "value": "" },
		{ "key": "job_slug", "value": "" },
		{ "key": "user_id", "value": "" },
		{ "key": "application_id", "value": "" },
		{ "key": "notification_id", "value": "" }
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/health",
						"header": []
					}
				}
			]
		},
		{
			"name": "Auth – User",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/register",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\",\n  \"full_name\": \"Test User\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('user_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/login",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\"\n}"
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/logout",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						]
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.collectionVariables.set('user_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/refresh",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
						}
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/forgot-password",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\"\n}"
						}
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/reset-password",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"PASTE_RESET_TOKEN_HERE\",\n  \"new_password\": \"NewSecurePass456\"\n}"
						}
					}
				},
				{
					"name": "Verify Email",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/auth/verify-email/PASTE_VERIFY_TOKEN_HERE",
						"header": []
					}
				},
				{
					"name": "CSRF Token",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/auth/csrf-token",
						"header": []
					}
				}
			]
		},
