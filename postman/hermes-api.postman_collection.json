{
  "info": {
    "name": "Hermes API",
    "description": "Complete API collection for the Hermes job portal backend.\n\n**Base URL:** `http://localhost:5001/api/v1`\n\n**Setup:**\n1. Set the `base_url` variable to your backend address\n2. Run `POST /auth/login` — the `access_token` variable is set automatically\n3. All protected routes use `Bearer {{access_token}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5001/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "job_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "notification_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if the backend API is running. No authentication required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"full_name\": \"John Doe\",\n  \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user account. Returns JWT tokens on success."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password. Automatically sets `access_token` and `refresh_token` collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refresh_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Exchange the refresh token for a new access token. Updates `access_token` variable automatically."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('access_token', '');",
                  "  pm.collectionVariables.set('refresh_token', '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Invalidate the current access token. Clears both token variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Get the authenticated user's full profile including education, physical details, and category."
          },
          "response": []
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"phone\": \"+919876543210\",\n  \"date_of_birth\": \"1995-06-15\",\n  \"gender\": \"Male\",\n  \"category\": \"General\",\n  \"state\": \"Maharashtra\",\n  \"city\": \"Mumbai\",\n  \"pincode\": \"400001\",\n  \"highest_qualification\": \"Graduate\",\n  \"education\": {\n    \"degree\": \"B.Tech\",\n    \"stream\": \"Computer Science\",\n    \"university\": \"Mumbai University\",\n    \"year\": 2018,\n    \"percentage\": 75.5\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Update the authenticated user's profile fields."
          },
          "response": []
        },
        {
          "name": "Get Preferences",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/preferences",
              "host": ["{{base_url}}"],
              "path": ["users", "preferences"]
            },
            "description": "Get the user's notification and job matching preferences."
          },
          "response": []
        },
        {
          "name": "Update Preferences",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notification_preferences\": {\n    \"email\": true,\n    \"push\": true,\n    \"sms\": false,\n    \"frequency\": \"daily\"\n  },\n  \"quick_filters\": {\n    \"job_types\": [\"latest_job\", \"result\"],\n    \"qualifications\": [\"Graduate\"],\n    \"states\": [\"Maharashtra\", \"Delhi\"]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/preferences",
              "host": ["{{base_url}}"],
              "path": ["users", "preferences"]
            },
            "description": "Update the user's notification and job matching preferences."
          },
          "response": []
        },
        {
          "name": "Get My Applications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/applications",
              "host": ["{{base_url}}"],
              "path": ["users", "applications"]
            },
            "description": "Get all job applications tracked by the authenticated user."
          },
          "response": []
        },
        {
          "name": "Track Job Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": \"{{job_id}}\",\n  \"application_number\": \"APP2024001234\",\n  \"is_priority\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/applications",
              "host": ["{{base_url}}"],
              "path": ["users", "applications"]
            },
            "description": "Start tracking a job application for the authenticated user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs?page=1&per_page=20&status=active&job_type=latest_job&qualification=Graduate&state=Maharashtra",
              "host": ["{{base_url}}"],
              "path": ["jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" },
                { "key": "status", "value": "active" },
                { "key": "job_type", "value": "latest_job", "description": "latest_job | result | admit_card | answer_key | admission | yojana" },
                { "key": "qualification", "value": "Graduate", "disabled": true },
                { "key": "state", "value": "Maharashtra", "disabled": true },
                { "key": "organization", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "description": "List all job vacancies with optional filters. Public endpoint — no auth required."
          },
          "response": []
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}"]
            },
            "description": "Get full details for a single job vacancy. Public endpoint — no auth required."
          },
          "response": []
        },
        {
          "name": "Create Job (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_title\": \"SSC CGL 2024\",\n  \"organization\": \"Staff Selection Commission\",\n  \"department\": \"Various Departments\",\n  \"job_type\": \"latest_job\",\n  \"employment_type\": \"permanent\",\n  \"qualification_level\": \"Graduate\",\n  \"total_vacancies\": 17727,\n  \"vacancy_breakdown\": {\n    \"General\": 8200,\n    \"OBC\": 4500,\n    \"SC\": 2700,\n    \"ST\": 1327,\n    \"EWS\": 1000\n  },\n  \"short_description\": \"SSC Combined Graduate Level Examination 2024\",\n  \"eligibility\": {\n    \"age_min\": 18,\n    \"age_max\": 32,\n    \"qualification\": \"Graduate from recognized university\",\n    \"nationality\": \"Indian\"\n  },\n  \"application_details\": {\n    \"fee_general\": 100,\n    \"fee_sc_st\": 0,\n    \"fee_women\": 0,\n    \"apply_link\": \"https://ssc.nic.in\"\n  },\n  \"notification_date\": \"2024-09-17\",\n  \"application_start\": \"2024-09-17\",\n  \"application_end\": \"2024-10-07\",\n  \"exam_start\": \"2024-12-09\",\n  \"salary_initial\": 25500,\n  \"salary_max\": 151100,\n  \"is_featured\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/jobs",
              "host": ["{{base_url}}"],
              "path": ["jobs"]
            },
            "description": "Create a new job vacancy. Requires Admin role."
          },
          "response": []
        },
        {
          "name": "Update Job (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"total_vacancies\": 18000,\n  \"is_featured\": true,\n  \"is_urgent\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}"]
            },
            "description": "Update a job vacancy. Requires Admin role."
          },
          "response": []
        },
        {
          "name": "Delete Job (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}"]
            },
            "description": "Delete a job vacancy. Requires Admin role."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/notifications?page=1&per_page=20&is_read=false",
              "host": ["{{base_url}}"],
              "path": ["notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" },
                { "key": "is_read", "value": "false", "description": "true | false — omit for all" }
              ]
            },
            "description": "Get notifications for the authenticated user. Filter by read/unread status."
          },
          "response": []
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/{{notification_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["notifications", "{{notification_id}}", "read"]
            },
            "description": "Mark a single notification as read."
          },
          "response": []
        },
        {
          "name": "Mark All Notifications as Read",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/read-all",
              "host": ["{{base_url}}"],
              "path": ["notifications", "read-all"]
            },
            "description": "Mark all of the authenticated user's notifications as read."
          },
          "response": []
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/{{notification_id}}",
              "host": ["{{base_url}}"],
              "path": ["notifications", "{{notification_id}}"]
            },
            "description": "Delete a specific notification."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/stats",
              "host": ["{{base_url}}"],
              "path": ["admin", "stats"]
            },
            "description": "Get dashboard statistics — total users, active jobs, applications, etc. Requires Admin role."
          },
          "response": []
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?page=1&per_page=20&status=active&role=user",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" },
                { "key": "status", "value": "active", "description": "active | suspended | deleted" },
                { "key": "role", "value": "user", "description": "user | admin | operator" }
              ]
            },
            "description": "List all registered users with filters. Requires Admin role."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}"]
            },
            "description": "Get full details for a specific user. Requires Admin role."
          },
          "response": []
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"suspended\",\n  \"reason\": \"Violation of terms of service\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "status"]
            },
            "description": "Update a user's status (active/suspended/deleted). Requires Admin role."
          },
          "response": []
        },
        {
          "name": "Analytics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/analytics?period=30d",
              "host": ["{{base_url}}"],
              "path": ["admin", "analytics"],
              "query": [
                { "key": "period", "value": "30d", "description": "7d | 30d | 90d | 1y" }
              ]
            },
            "description": "Get analytics data (page views, search trends, top jobs). Requires Admin role."
          },
          "response": []
        }
      ]
    }
  ]
}
